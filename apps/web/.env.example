GMAIL_CLIENT_ID=****
# Gmail OAuth client secret
GMAIL_CLIENT_SECRET=****
# Optional: OAuth redirect URI (defaults to https://<app>/api/gmail/callback)
# GMAIL_REDIRECT_URI=https://your-domain.com/api/gmail/callback

