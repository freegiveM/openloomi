# openssl rand -base64 32
AUTH_SECRET=****

# node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
ENCRYPTION_KEY=****

# Agent base url and token
ANTHROPIC_BASE_URL=****
ANTHROPIC_API_KEY=****
ANTHROPIC_AUTH_TOKEN=****
ANTHROPIC_MODEL=****

# Agent runtime provider (optional)
# CLI processes receive a restricted environment by default. Add any extra
# variable names they require as a comma-separated, server-controlled allowlist.
# OPENLOOMI_AGENT_ENV_ALLOWLIST=MY_CORPORATE_CA_BUNDLE,HTTPS_PROXY
# Claude Agent SDK is the default runtime. Leave the provider unset or select it
# explicitly; Claude uses the API/model configuration above and any saved user
# Anthropic-compatible setting.
# OPENLOOMI_AGENT_PROVIDER=claude
#
# Set to "opencode" to run native agent tasks through a
# locally installed OpenCode CLI. OpenCode is an AgentPlugin/IAgent runtime
# provider, not a sandbox provider, and it is not installed automatically.
# OPENLOOMI_AGENT_PROVIDER=opencode
# OPENLOOMI_AGENT_OPENCODE_COMMAND=opencode
# OPENLOOMI_AGENT_OPENCODE_MODEL=anthropic/claude-sonnet-4.6
# OPENLOOMI_AGENT_OPENCODE_AGENT=build
# OPENLOOMI_AGENT_OPENCODE_TIMEOUT_MS=300000
# --auto remains off by default. This only permits --auto when the request
# permission mode is also bypassPermissions.
# OPENLOOMI_AGENT_OPENCODE_ALLOW_AUTO_APPROVE=false
#
# Set to "hermes" to run native agent tasks through a locally installed Hermes
# ACP runtime. Hermes is an AgentPlugin/IAgent runtime provider, not a sandbox
# provider, and OpenLoomi does not install Hermes automatically.
# OPENLOOMI_AGENT_PROVIDER=hermes
# OPENLOOMI_AGENT_HERMES_COMMAND=hermes
# OPENLOOMI_AGENT_HERMES_PROFILE=coding
# OPENLOOMI_AGENT_HERMES_MODEL=anthropic/claude-sonnet-4.6
# Optional provider qualifier; requires OPENLOOMI_AGENT_HERMES_MODEL.
# OPENLOOMI_AGENT_HERMES_PROVIDER=openrouter
# OPENLOOMI_AGENT_HERMES_TIMEOUT_MS=300000
# Hermes --yolo is not enabled by OpenLoomi. The selected model is applied to
# each ACP session through session/set_model; credentials still come from the
# selected Hermes profile/config.
#
# Set to "openclaw" to connect OpenLoomi to an OpenClaw Gateway through the
# official `openclaw acp` stdio bridge. Prefer token/password files or the
# OPENCLAW_GATEWAY_* environment variables; secrets passed as CLI arguments can
# be visible in process listings.
# OPENLOOMI_AGENT_PROVIDER=openclaw
# OPENLOOMI_AGENT_OPENCLAW_COMMAND=openclaw
# OPENLOOMI_AGENT_OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
# OPENLOOMI_AGENT_OPENCLAW_TOKEN_FILE=/path/to/gateway.token
# OPENLOOMI_AGENT_OPENCLAW_PASSWORD_FILE=/path/to/gateway.password
# OPENLOOMI_AGENT_OPENCLAW_SESSION=agent:main:main
# OPENLOOMI_AGENT_OPENCLAW_SESSION_LABEL=
# OPENLOOMI_AGENT_OPENCLAW_REQUIRE_EXISTING=false
# OPENLOOMI_AGENT_OPENCLAW_RESET_SESSION=false
# OPENLOOMI_AGENT_OPENCLAW_NO_PREFIX_CWD=false
# OPENLOOMI_AGENT_OPENCLAW_PROVENANCE=meta
# OPENLOOMI_AGENT_OPENCLAW_TIMEOUT_MS=300000
#
# Set to "codex" to run native agent tasks through an authenticated local
# Codex CLI. OpenLoomi uses `codex exec --json`; Codex auth/config remains in
# the CLI's normal home (or CODEX_HOME). Current Codex releases deprecate
# --full-auto, so prefer an explicit sandbox and keep FULL_AUTO disabled.
# OPENLOOMI_AGENT_PROVIDER=codex
# OPENLOOMI_AGENT_CODEX_COMMAND=codex
# OPENLOOMI_AGENT_CODEX_PROFILE=
# OPENLOOMI_AGENT_CODEX_MODEL=
# OPENLOOMI_AGENT_CODEX_SANDBOX=workspace-write
# OPENLOOMI_AGENT_CODEX_SKIP_GIT_REPO_CHECK=true
# OPENLOOMI_AGENT_CODEX_FULL_AUTO=false
# OPENLOOMI_AGENT_CODEX_TIMEOUT_MS=300000

# Embedding provider selection
# cloud: use OpenAI-compatible embedding APIs configured below (current default)
# local: use Transformers.js feature-extraction models in-process
# EMBEDDING_PROVIDER=cloud
# EMBEDDING_PROVIDER=local
#
# Local Transformers.js embedding options:
# LOCAL_EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
# LOCAL_EMBEDDING_BATCH_SIZE=8
# LOCAL_EMBEDDING_MAX_TOKENS=512
# LOCAL_EMBEDDING_CACHE_DIR=.openloomi/models
# Optional model download host. Use the mirror if huggingface.co is unavailable
# or slow in your network environment.
# LOCAL_EMBEDDING_REMOTE_HOST=https://hf-mirror.com
# LOCAL_EMBEDDING_DEVICE=cpu
# LOCAL_EMBEDDING_DTYPE=fp32
# LOCAL_EMBEDDING_LOCAL_ONLY=false

# OpenAI Audio API (Whisper + TTS) — OPTIONAL, only required if you use
# Whisper transcription or TTS. Chat and embeddings do not need this.
# Get your key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=****
# Optional: Custom base URL for OpenAI Audio API (defaults to https://api.openai.com/v1)
# OPENAI_AUDIO_BASE_URL=https://api.openai.com/v1

# Image Generation API (Lifestyle image Day 1 backend)
# Provider selection: openai | openrouter | nano-banana
# Keep real keys in apps/web/.env.local only. Do not commit local secrets.
#
# IMAGE_GENERATION_PROVIDER=openrouter
# Optional global timeout for slow image providers.
# IMAGE_GENERATION_TIMEOUT_MS=120000
#
# Official OpenAI Images API.
# Reuses OPENAI_API_KEY above.
# OPENAI_IMAGE_MODEL=gpt-image-2
# OPENAI_IMAGE_BASE_URL=https://api.openai.com/v1
# Optional full endpoint override. If set, this is used exactly and no path is appended.
# OPENAI_IMAGE_GENERATION_URL=https://api.openai.com/v1/images/generations
# OPENAI_IMAGE_TIMEOUT_MS=120000
#
# OpenRouter Images API.
# API docs: https://openrouter.ai/docs/api/api-reference/images/generate-an-image
# OPENROUTER_API_KEY=****
# OPENROUTER_IMAGE_MODEL=bytedance-seed/seedream-4.5
# OPENROUTER_IMAGE_BASE_URL=https://openrouter.ai/api/v1
# Optional full endpoint override. If set, this is used exactly and no path is appended.
# OPENROUTER_IMAGE_GENERATION_URL=https://openrouter.ai/api/v1/images
# OPENROUTER_IMAGE_TIMEOUT_MS=120000
#
# Nano Banana or custom image provider.
# Use IMAGE_GENERATION_URL when the provider gives a full endpoint.
# Use BASE_URL only for OpenAI-compatible APIs where /v1/images/generations
# should be appended automatically.
# NANO_BANANA_API_KEY=****
# NANO_BANANA_MODEL=nano-banana
# NANO_BANANA_BASE_URL=https://provider.example/v1
# NANO_BANANA_IMAGE_GENERATION_URL=https://provider.example/draw
# NANO_BANANA_TIMEOUT_MS=120000

# Vector store backend configuration (optional)
# Desktop defaults to sqlite-vec. Set individual backends to "chroma" to use
# ChromaDB as the semantic vector index instead.
#
# Chroma runs as a separate vector database service. SQLite/Postgres still remain
# the source of truth for documents, raw messages, and insights.
#
# Global fallback for knowledge, raw messages, and insights:
# VECTOR_STORE_BACKEND=sqlite-vec
# VECTOR_STORE_BACKEND=chroma
#
# Knowledge base / RAG chunks:
# RAG_VECTOR_STORE_BACKEND=sqlite-vec
# SQLITE_VEC_RAG_COLLECTION=openloomi_rag_chunks
# RAG_VECTOR_STORE_BACKEND=chroma
# CHROMA_RAG_COLLECTION=openloomi_rag_chunks
#
# Raw message semantic memory:
# RAW_MESSAGE_VECTOR_STORE_BACKEND=sqlite-vec
# RAW_MESSAGE_VECTOR_STORE_BACKEND=chroma
# CHROMA_RAW_MESSAGES_COLLECTION=openloomi_raw_messages
#
# Insight semantic search:
# INSIGHT_VECTOR_STORE_BACKEND=sqlite-vec
# SQLITE_VEC_INSIGHTS_COLLECTION=openloomi_insights
# INSIGHT_VECTOR_STORE_BACKEND=chroma
# CHROMA_INSIGHTS_COLLECTION=openloomi_insights
#
# Chroma server URL:
# CHROMA_URL=http://localhost:8000

# Brave Search API (optional) - Get API key from https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=****

# --- Self-hosted architecture ---
#
# openloomi is fully self-hosted by default. The Tauri desktop app uses a local
# SQLite database; no cloud account, API key, or SaaS endpoint is required to
# run the core product. The variables below are OPTIONAL — only configure
# them when you need a specific capability.

# Optional: Vercel Blob Store for hosted (non-Tauri) deployments.
# Instructions: https://vercel.com/docs/storage/vercel-blob
# BLOB_READ_WRITE_TOKEN=****

# Optional: PostgreSQL for hosted (non-Tauri) deployments.
# Default desktop install uses local SQLite and ignores this.
# Instructions: https://vercel.com/docs/storage/vercel-postgres/quickstart
# POSTGRES_URL=****

# Optional: Redis cache for hosted (non-Tauri) deployments.
# Default desktop install uses an in-process LRU and ignores this.
# Instructions: https://vercel.com/docs/redis
# REDIS_URL=****

# Optional: Absolute base URL used as the OAuth `redirect_uri` origin for
# third-party integrations (Slack, Discord, X, LinkedIn, Notion, HubSpot,
# etc.). OAuth providers require an absolute URL, so a relative path will
# not work. Leave unset to fall back to NEXT_PUBLIC_APP_URL.
#
# Self-hosted Tauri usage: leave this unset (the Tauri webview serves
# the local Next.js server, so a configured callback is rare).
#
# Hosted usage: set this to the public HTTPS URL of your deployment.
# CLOUD_API_URL=https://your-deployment.example.com

# Default telegram bot token name and token (optional, just for test)
TG_BOT_NAME=****
TG_BOT_TOKEN=****
TG_SESSION=****

