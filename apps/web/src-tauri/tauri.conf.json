{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "openloomi",
  "version": "0.8.0",
  "identifier": "com.openloomi.app",
  "build": {
    "beforeDevCommand": "node scripts/run-tauri-dev.js",
    "beforeBuildCommand": "node scripts/run-tauri-build.js",
    "devUrl": "http://localhost:3515",
    "frontendDist": "../.next/standalone/apps/web/public"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "openloomi",
        "width": 1280,
        "height": 800,
        "minWidth": 450,
        "minHeight": 600,
        "dragDropEnabled": false,
        "url": "about:blank",
        "visible": false,
        "focus": false
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' blob: data:; script-src 'self' 'unsafe-inline' 'unsafe-eval' blob: data: tauri: https://unpkg.com https://cdn.jsdelivr.net https://cdn.tailwindcss.com https://geddle.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.tailwindcss.com; img-src 'self' data: https: http: blob: asset: http://asset.localhost https://asset.localhost; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https: http: wss: blob: data: tauri: ipc: https://unpkg.com https://cdn.jsdelivr.net https://cdn.tailwindcss.com https://fonts.googleapis.com; frame-src 'self' blob:; object-src 'none'; base-uri 'self'; form-action 'self';",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/.openloomi/pet-custom/**",
          "$HOME/.openloomi/pet-config.json",
          "$HOME/**"
        ]
      },
      "capabilities": ["default", "loomi-pet"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.iconset/icon_512x512@2x.png",
      "icons/icon.iconset/icon_256x256.png",
      "icons/icon.iconset/icon_128x128.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/128x128.png",
      "icons/32x32.png"
    ],
    "category": "Productivity",
    "shortDescription": "openloomi AI Assistant",
    "longDescription": "openloomi AI Assistant - Your Personal Productivity Tool. Integrate all your messaging platforms and get AI-powered insights.",
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.13",
      "entitlements": "entitlements.plist",
      "providerShortName": null,
      "signingIdentity": null
    },
    "resources": [
      "cli/**/*",
      "../../../skills/**/*",
      "../.next/standalone/**/*",
      "../.next/standalone/apps/web/.next/**/*",
      "../.next/standalone/apps/web/lib/**/*",
      "../.next/standalone/apps/web/cli-bundle/**/*",
      "../.next/standalone/apps/web/server.js",
      "../.next/standalone/apps/web/public/**/*",
      "../.env",
      "resources/loading.html",
      "resources/render-engine/**/*",
      "resources/render-engine-manifest.json"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "fs": {}
  }
}