{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for main window",
  "windows": ["main"],
  "remote": {
    "urls": ["http://localhost:*/*", "http://127.0.0.1:*/*"]
  },
  "permissions": [
    "core:default",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "core:event:allow-emit-to",
    "core:event:allow-unlisten",
    "core:app:default",
    "core:window:default",
    "core:window:allow-start-dragging",
    "core:menu:default",
    "window-state:default",
    "shell:default",
    "dialog:allow-open",
    "dialog:allow-confirm",
    "opener:default",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-read-dir",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-exists",
    "allow-get-data-directory",
    "allow-get-storage-directory",
    "allow-get-memory-directory",
    "allow-get-bundled-skills-dir",
    "allow-get-app-info",
    "allow-get-host-os",
    "allow-open-url-custom",
    "allow-open-path-custom",
    "allow-pick-folder-dialog",
    "allow-read-file-custom",
    "allow-file-stat-custom",
    "allow-file-exists-custom",
    "allow-mkdir-custom",
    "allow-write-text-file-custom",
    "allow-read-text-file-custom",
    "allow-remove-file-custom",
    "allow-reveal-item-in-dir-custom",
    "allow-copy-file-to-clipboard",
    "allow-home-dir-custom",
    "allow-capture-screen",
    "allow-register-screen-capture-shortcut",
    "allow-unregister-screen-capture-shortcut",
    "allow-test-global-shortcut",
    "allow-start-system-audio-capture",
    "allow-stop-system-audio-capture",
    "allow-is-system-audio-capture-active",
    "allow-save-token",
    "allow-load-token",
    "allow-delete-token",
    "allow-get-server-status",
    "allow-restart-server",
    "allow-check-for-update",
    "allow-start-update-download",
    "allow-poll-update-download-progress",
    "allow-finish-update-download",
    "allow-restart-for-update",
    "allow-detect-telegram-desktop",
    "allow-check-custom-telegram-path",
    "allow-send-notification",
    "allow-get-render-engine-status-cmd",
    "allow-ensure-render-engine-download-started-cmd",
    "allow-list-workspace-artifacts",
    "allow-check-system-permissions",
    "allow-request-folder-access",
    "allow-request-screen-recording-access",
    "allow-request-system-audio-access",
    "allow-request-accessibility-access",
    "allow-request-microphone-access",
    "allow-request-notification-access",
    "allow-open-system-settings",
    "notification:default",
    "notification:allow-is-permission-granted",
    "notification:allow-request-permission",
    "notification:allow-notify",
    "global-shortcut:default",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "global-shortcut:allow-is-registered",
    {
      "identifier": "fs:allow-stat",
      "allow": [
        "$HOME/.openloomi/**",
        "$HOME/.agent/**",
        "$HOME/.claude/**",
        "$HOME/**",
        "$HOME/Library/Messages/**",
        "$HOME/Library/**",
        "$DESKTOP/**",
        "$DOWNLOAD/**",
        "$DOCUMENT/**",
        "$APPDATA/**",
        "$TEMP/**",
        "$RESOURCE/**",
        "/**"
      ]
    },
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        "$HOME/.openloomi/**",
        "$HOME/.agent/**",
        "$HOME/.claude/**",
        "$HOME/**",
        "$HOME/Library/Messages/**",
        "$HOME/Library/**",
        "$DESKTOP/**",
        "$DOWNLOAD/**",
        "$DOCUMENT/**",
        "$APPDATA/**",
        "$TEMP/**",
        "$RESOURCE/**",
        "/**"
      ]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        "$HOME/.openloomi/**",
        "$HOME/.agent/**",
        "$HOME/.claude/**",
        "$HOME/**",
        "$HOME/Library/Messages/**",
        "$HOME/Library/**",
        "$DESKTOP/**",
        "$DOWNLOAD/**",
        "$DOCUMENT/**",
        "$APPDATA/**",
        "$TEMP/**",
        "$RESOURCE/**",
        "/**"
      ]
    }
  ]
}
